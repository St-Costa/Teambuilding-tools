{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gdr-teambuilding-tool",
  "version": "0.1.0",
  "identifier": "com.teambuilding.gdr",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "control",
        "title": "Regia",
        "url": "control.html",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": true
      },
      {
        "label": "stage",
        "title": "Proiezione",
        "url": "stage.html",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
